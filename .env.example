# Database (local PostgreSQL 17 — Homebrew: brew services start postgresql@17)
DATABASE_URL=postgresql://aqa:aqa@localhost:5432/autonomous_qa

# Redis / Celery (local Redis — Homebrew: brew install redis && brew services start redis)
REDIS_URL=redis://localhost:6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# API (FastAPI)
API_PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Database migrations: alembic upgrade head
# Existing DB from Prisma: alembic stamp head

# Artifacts (local)
ARTIFACT_STORAGE_PATH=./artifacts

# LLM (TestDesign + Discovery flow structuring; rule-based fallback when unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5-mini
GEMINI_API_KEY=
LLM_BUDGET_PER_PIPELINE=2.00
LLM_BUDGET_PER_APP_DAILY=10.00

# Artifact retention (days, 0 = never delete). Used by cleanup_artifacts Celery beat task.
ARTIFACT_RETENTION_DAYS=30
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# Target app credentials (referenced by auth_config.credentials_secret_ref — Day 18+)
# JUICE_SHOP_TEST_USER={"email":"admin@juice-sh.op","password":"admin123"}
