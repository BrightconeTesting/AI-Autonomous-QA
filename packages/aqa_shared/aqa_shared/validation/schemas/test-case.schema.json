{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autonomous-qa.dev/schemas/testcase/v1",
  "title": "TestCase",
  "type": "object",
  "required": ["name", "steps", "priority"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "priority": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"]
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["action", "target"],
        "properties": {
          "action": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
